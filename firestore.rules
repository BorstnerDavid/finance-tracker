rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can only read/write documents under their own uid.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Households: a shared pool of data for 2+ members. The document id doubles as
    // the join code, so any signed-in user may fetch ONE household doc by id (needed
    // to look it up before joining) — but listing/querying the collection is
    // restricted to members only, so nobody can enumerate other people's households.
    match /households/{hid} {
      allow get: if request.auth != null;
      allow list: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.resource.data.members == [request.auth.uid]
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null && (
        // existing members can change anything (add/remove members, rename, etc.)
        request.auth.uid in resource.data.members ||
        // OR a non-member may join by appending only themselves to `members`
        (request.auth.uid in request.resource.data.members &&
         request.resource.data.members.size() == resource.data.members.size() + 1 &&
         request.resource.data.members.hasAll(resource.data.members))
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;

      match /{document=**} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(hid)).data.members;
      }
    }
  }
}
